# MagDrive server config — copy to server/.env and fill in. NEVER commit .env (Rule #8).

# HTTP
PORT=4000
# Comma-separated allowed origins for CORS (the Vite dev client)
CORS_ORIGIN=http://localhost:5173

# Auth — generate a long random string for production. Rotate quarterly.
JWT_SECRET=dev-only-change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=7d

# Storage adapter: "local" (disk) or "s3" (AWS S3 / Cloudflare R2 — S3-compatible)
STORAGE_DRIVER=local
# Where local files live (relative to server/). Ignored when STORAGE_DRIVER=s3.
LOCAL_STORAGE_DIR=data/uploads
# Per-file upload cap in bytes (default 5 GiB). Storage upload paths are user-scoped + size-capped (Checklist: Security).
MAX_FILE_BYTES=5368709120

# --- S3 / R2 (only needed when STORAGE_DRIVER=s3) ---
S3_BUCKET=
S3_REGION=auto
# For Cloudflare R2 / MinIO set the endpoint; leave blank for AWS S3.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# SQLite file (relative to server/)
DB_PATH=data/magdrive.sqlite

# --- Cloud connectors (optional) ---
# Public URLs used to build OAuth redirects. In local dev the defaults are fine.
API_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# Google Drive — create an OAuth 2.0 Client (type: Web application) at
#   https://console.cloud.google.com/apis/credentials
# Enable the "Google Drive API", configure the OAuth consent screen (add your
# email as a test user), and set the Authorized redirect URI to EXACTLY:
#   http://localhost:4000/api/connect/google/callback
# Scopes used: drive.readonly + email/profile. Leave blank to hide Google connect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox — create an app (scoped, "Full Dropbox" or "App folder") at
#   https://www.dropbox.com/developers/apps
# Add the redirect URI: http://localhost:4000/api/connect/dropbox/callback
# Enable permissions: files.metadata.read + files.content.read. Use refresh tokens.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# ===================================================================
# Pre-launch SaaS features (all OPTIONAL — each stays inert until set)
# ===================================================================

# --- Branding / support (legal pages + transactional email + feedback routing) ---
APP_NAME=MagDrive
COMPANY_NAME=MagDrive
SUPPORT_EMAIL=support@magdrive.app

# --- Transactional email (SMTP via nodemailer) ---
# Used for email verification, password reset, and feedback notifications.
# Leave SMTP_HOST blank to disable sending (links are logged to the server console in dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@magdrive.app

# --- Payments (Stripe) ---
# Create a recurring Price in the Stripe dashboard and paste its id below.
# Webhook: add an endpoint pointing to <API_URL>/api/billing/webhook and copy its signing secret.
# Subscribe to: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Leave STRIPE_SECRET_KEY blank to disable billing (UI shows "not configured").
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- "Sign in with Google" (reuses GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET above) ---
# Set to "true" AND provide the Google client creds to enable the login button.
# Add this Authorized redirect URI to the SAME OAuth client, EXACTLY:
#   http://localhost:4000/api/auth/google/callback
GOOGLE_AUTH_ENABLED=false
